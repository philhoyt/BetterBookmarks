{
    "name": "better-bookmarks",
    "version": "1.1.0",
    "description": "A link card block with Open Graph preview support.",
    "scripts": {
        "build": "wp-scripts build --webpack-src-dir=src --output-path=build",
        "start": "wp-scripts start --webpack-src-dir=src --output-path=build",
        "lint:js": "wp-scripts lint-js src",
        "lint:css": "wp-scripts lint-style 'src/**/*.css'",
        "lint": "npm run lint:js && npm run lint:css",
        "test:js": "wp-scripts test-unit-js",
        "test:php": "vendor/bin/phpunit",
        "test": "npm run test:js && npm run test:php",
        "plugin-zip": "wp-scripts plugin-zip"
    },
    "files": [
        "better-bookmarks.php",
        "readme.txt",
        "build",
        "includes",
        "lib"
    ],
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@wordpress/scripts": "^30.0.0"
    }
}
