{
    "name": "philhoyt/better-bookmarks",
    "description": "A link card block with Open Graph preview support.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "yahnis-elsts/plugin-update-checker": "^5.3"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6"
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "test": "phpunit",
        "copy-puc": "rsync -a --delete vendor/yahnis-elsts/plugin-update-checker/ lib/plugin-update-checker/",
        "post-install-cmd": "@copy-puc",
        "post-update-cmd": "@copy-puc"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
