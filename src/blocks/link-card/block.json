{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "better-bookmarks/link-card",
    "version": "1.0.4",
    "title": "Link Card",
    "category": "better-bookmarks",
    "description": "Displays a rich link preview card using Open Graph metadata.",
    "keywords": [ "link", "bookmark", "card", "og", "preview", "better-bookmarks" ],
    "textdomain": "better-bookmarks",
    "attributes": {
        "url":         { "type": "string",  "default": "" },
        "title":       { "type": "string",  "default": "" },
        "description": { "type": "string",  "default": "" },
        "image":       { "type": "string",  "default": "" },
        "domain":      { "type": "string",  "default": "" },
        "imageWidth":       { "type": "integer", "default": 0 },
        "imageHeight":      { "type": "integer", "default": 0 },
        "imageAspectRatio": { "type": "string",  "default": "" }
    },
    "supports": {
        "html":      false,
        "reusable":  true,
        "anchor":    true,
        "renaming":  true,
        "align":     true,
        "color": {
            "background": true,
            "text":       true
        },
        "shadow":    true,
        "border": {
            "color":  true,
            "radius": true,
            "style":  true,
            "width":  true
        },
        "spacing": {
            "margin":  [ "top", "bottom" ],
            "padding": true
        }
    },
    "styles": [
        { "name": "default", "label": "Default", "isDefault": true },
        { "name": "compact", "label": "Compact" },
        { "name": "compact-stacked", "label": "Compact Stacked" },
        { "name": "minimal", "label": "Minimal" }
    ],
    "editorScript": "file:./index.js",
    "style":         "file:./style-index.css",
    "render":        "file:./render.php"
}
