{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "better-bookmarks/link-card",
    "version": "1.0.0",
    "title": "Link Card",
    "category": "better-bookmarks",
    "description": "Displays a rich link preview card using Open Graph metadata.",
    "keywords": [ "link", "bookmark", "card", "og", "preview", "better-bookmarks" ],
    "textdomain": "better-bookmarks",
    "attributes": {
        "url":         { "type": "string",  "default": "" },
        "title":       { "type": "string",  "default": "" },
        "description": { "type": "string",  "default": "" },
        "image":       { "type": "string",  "default": "" },
        "domain":      { "type": "string",  "default": "" }
    },
    "supports": {
        "html":      false,
        "reusable":  true,
        "align":     [ "wide" ]
    },
    "editorScript": "file:./index.js",
    "style":         "file:./style-index.css",
    "render":        "file:./render.php"
}
